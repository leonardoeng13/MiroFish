# LLM API configuration (supports any LLM API in OpenAI SDK format)
# Recommended: OpenAI (https://platform.openai.com/) or compatible providers
# Note: High token consumption. Start with simulations under 40 rounds to test costs.
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# ===== ZEP knowledge graph configuration =====
#
# Option A – Zep Cloud (easiest to start, free tier available)
#   Sign up at https://app.getzep.com/ and paste your key below.
#   Leave ZEP_BASE_URL unset (or remove it entirely).
#
# Option B – Local Zep CE (self-hosted, no daily limit)
#   1. Copy zep.yaml.example → zep.yaml
#   2. Run: docker compose --profile local-zep up -d
#   3. Set ZEP_BASE_URL below (use localhost when running MiroFish outside Docker,
#      or http://zep:8000 when mirofish also runs in Docker Compose)
#   4. OPENAI_API_KEY is required for the Graphiti service used by Zep CE.
#
ZEP_API_KEY=your_zep_api_key_here
# ZEP_BASE_URL=http://localhost:8000   # Uncomment for local Zep CE (outside Docker)
# ZEP_BASE_URL=http://zep:8000         # Uncomment for local Zep CE (inside Docker Compose)

# ===== OPENAI_API_KEY (required when using local Zep CE) =====
# The Graphiti knowledge graph service bundled with Zep CE requires an OpenAI key.
# Not needed if you are using Zep Cloud (Option A above).
# OPENAI_API_KEY=your_openai_api_key_here

# ===== Accelerated LLM configuration (optional) =====
# Note: do NOT include the lines below if you are not using a boost configuration
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here