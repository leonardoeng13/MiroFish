# Zep Community Edition (CE) configuration
# ==========================================
# Copy this file to zep.yaml before running `docker compose --profile local-zep up -d`
# See: https://help.getzep.com/ce/quickstart

auth:
  # Disable authentication for local development. Set to true in production.
  required: false

graphiti:
  # Address of the Graphiti service (container name matches docker-compose service)
  uri: "http://graphiti:8003"

store:
  type: postgres
  postgres:
    # Connection string for the zep-db service defined in docker-compose.yml
    dsn: "postgres://postgres:postgres@zep-db:5432/postgres?sslmode=disable"
